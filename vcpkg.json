{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    "abseil",
    {
      "name": "cpp-httplib",
      "default-features": false,
      "features": [
        "zlib"
      ]
    },
    {
      "name": "curl",
      "default-features": false,
      "features": [
        "ssl"
      ],
      "platform": "(windows & !uwp) | mingw"
    },
    {
      "name": "curl",
      "default-features": false,
      "features": [
        "wolfssl"
      ],
      "platform": "(uwp | !windows) & !mingw"
    },
    "fmt",
    {
      "name": "libuv",
      "platform": "windows | android"
    },
    "ncnn",
    "nlohmann-json",
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "jpeg",
        "png",
        "tiff",
        "webp"
      ]
    },
    "pthreadpool",
    "quickjs-ng",
    "sqlite3",
    "tensorflow-lite",
    "tesseract",
    {
      "name": "uwebsockets",
      "features": [
        "zlib"
      ]
    }
  ]
}
